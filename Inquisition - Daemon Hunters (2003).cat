      </modifiers>
      <constraints>
        <constraint field="selections" scope="force" value="1" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="e38a-abb3-d8c2-9f48" type="max"/>
      </constraints>
      <rules>
        <rule id="d35c-9cf1-1396-3483" name="The Strands of Fate" hidden="false">
          <description>Stern may re-roll one dice roll per phase. Keep track of the number of times Stern uses this ability in a given player turn. His opponent may subsequently re-roll one of his own units&apos; dice per use of this ability. Any re-rolls garnered in this way that are not utilised by the end of the player turn are lost.</description>
        </rule>
        <rule id="c451-7c48-58bd-24ab" name="Daemonic Nemesis" hidden="false">
          <description>Any opponent using the Adversaries rules may upgrade their Greater Daemon to Chaos to a Lord of Change for no extra cost.</description>
        </rule>
      </rules>
      <infoLinks>
