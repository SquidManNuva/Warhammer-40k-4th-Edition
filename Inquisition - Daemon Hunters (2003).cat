              </constraints>
              <infoLinks>
                <infoLink id="f531-de2e-be78-7a92" name="Melta Bombs" hidden="false" targetId="87d0-8c40-7bcb-8cbb" type="profile"/>
              </infoLinks>
              <costs>
                <cost name="pts" typeId="4ed5-2f92-9abc-2870" value="5"/>
              </costs>
            </selectionEntry>
            <selectionEntry id="92f4-3432-e418-aad8" name="Purity Seals" hidden="false" collective="false" import="true" type="upgrade">
              <constraints>
                <constraint field="selections" scope="parent" value="1" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="a261-3bbe-4450-df80" type="max"/>
              </constraints>
              <rules>
                <rule id="ea86-c318-e868-7ddc" name="Purity Seals" hidden="false">
                  <description>When a unit including a model wearing Purity Seals falls back, roll one extra D6 for the fall back distance, and then pick the D6 results you want.</description>
                </rule>
              </rules>
              <costs>
                <cost name="pts" typeId="4ed5-2f92-9abc-2870" value="5"/>
              </costs>
            </selectionEntry>
            <selectionEntry id="278a-ae08-1ee9-0667" name="Iron Halo" hidden="false" collective="false" import="true" type="upgrade">
              <constraints>
                <constraint field="selections" scope="force" value="1" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="fb65-4bf2-9eeb-fe09" type="max"/>
                <constraint field="selections" scope="parent" value="1" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="bcb3-2685-0d60-c8c5" type="max"/>
              </constraints>
              <rules>
                <rule id="8fde-bb0a-2828-184f" name="Iron Halo" hidden="false">
                  <description>The iron halo grants a 4+ invilnerable save.</description>
                </rule>
              </rules>
              <costs>
                <cost name="pts" typeId="4ed5-2f92-9abc-2870" value="25"/>
              </costs>
            </selectionEntry>
          </selectionEntries>
        </selectionEntryGroup>
      </selectionEntryGroups>
    </selectionEntryGroup>
    <selectionEntryGroup id="28e7-a207-4e89-bcb5" name="Space Marine Vehicle Upgrades" hidden="false" collective="false" import="true">
      <selectionEntries>
        <selectionEntry id="28f0-8f6a-8958-03b8" name="Dozer Blade" hidden="false" collective="false" import="true" type="upgrade">
          <modifiers>
            <modifier type="set" field="hidden" value="true">
              <conditions>
                <condition field="selections" scope="ancestor" value="1" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" childId="6852-d18d-8c5c-5c96" type="instanceOf"/>
              </conditions>
            </modifier>
          </modifiers>
          <constraints>
            <constraint field="selections" scope="parent" value="1" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="40e6-3d89-ea67-d31d" type="max"/>
          </constraints>
          <rules>
            <rule id="8678-bebd-36b3-bc24" name="Dozer Blade" hidden="false">
              <description>Re-roll failed Difficult Terrain tests as long as the model did not move more than 6&quot; that turn.</description>
            </rule>
          </rules>
          <costs>
            <cost name="pts" typeId="4ed5-2f92-9abc-2870" value="5"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="ed29-cfc4-3d99-48c0" name="Extra Armor" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="7501-945a-01d0-a4d2" type="max"/>
          </constraints>
          <rules>
            <rule id="7558-6c22-6084-a0a4" name="Extra Armour" hidden="false">
              <description>Treat &apos;Crew Stunned&apos; results as &apos;Crew Shaken&apos; instead.</description>
            </rule>
          </rules>
          <costs>
            <cost name="pts" typeId="4ed5-2f92-9abc-2870" value="5"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="2411-b66f-db92-87eb" name="Hunter-killer Missile" hidden="false" collective="false" import="true" type="upgrade">
          <modifiers>
            <modifier type="set" field="hidden" value="true">
              <conditions>
                <condition field="selections" scope="ancestor" value="1" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" childId="6852-d18d-8c5c-5c96" type="instanceOf"/>
              </conditions>
            </modifier>
          </modifiers>
          <constraints>
            <constraint field="selections" scope="parent" value="1" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="bdbf-cb8c-c699-fe0f" type="max"/>
          </constraints>
          <infoLinks>
            <infoLink id="acd2-e718-2960-68bc" name="Hunter-killer Missile" hidden="false" targetId="86d5-c5a0-fc04-7f5a" type="profile"/>
          </infoLinks>
          <costs>
            <cost name="pts" typeId="4ed5-2f92-9abc-2870" value="15"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="7fb1-5a3d-a72f-f887" name="Pintle-mounted Storm Bolter" hidden="false" collective="false" import="true" type="upgrade">
          <modifiers>
            <modifier type="set" field="hidden" value="true">
              <conditions>
                <condition field="selections" scope="ancestor" value="1" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" childId="6852-d18d-8c5c-5c96" type="instanceOf"/>
              </conditions>
            </modifier>
          </modifiers>
          <constraints>
            <constraint field="selections" scope="parent" value="1" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="aa77-45aa-b16a-3f3e" type="max"/>
          </constraints>
          <infoLinks>
            <infoLink id="4ebd-d5c0-ae10-f8c9" name="Storm Bolter" hidden="false" targetId="4c6c-9de1-00a8-8016" type="profile"/>
          </infoLinks>
          <costs>
            <cost name="pts" typeId="4ed5-2f92-9abc-2870" value="10"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="b6f6-28c6-5db5-e459" name="Searchlight" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="823a-0298-0857-b476" type="max"/>
          </constraints>
          <rules>
            <rule id="95c8-4283-f9e7-5b84" name="Searchlight" hidden="false">
              <description>During battles using Night Fight rules, one enemy unit spotted by the vehicle may be fired at by all other friendly units within range and that have line of sight, but by doing so the vehicle may be fired at by all enemy units in the next turn.</description>
            </rule>
          </rules>
          <costs>
            <cost name="pts" typeId="4ed5-2f92-9abc-2870" value="1"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="b102-3dec-f417-2464" name="Smoke Launchers" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="a120-ccbd-160c-43ce" type="max"/>
          </constraints>
          <rules>
            <rule id="61b9-d88d-76eb-8f68" name="Smoke Launchers" hidden="false">
              <description>Once per game, after completing its move, a vehicle with Smoke Launchers may trigger them. The vehicle may not fire this turn, but any penetrating hits scored by the enemy in the next shooting phase are instead turned into glancing hits.</description>
            </rule>
          </rules>
          <costs>
            <cost name="pts" typeId="4ed5-2f92-9abc-2870" value="3"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="61f9-f5a5-de01-6e89" name="Navy Vehicle Upgrades" hidden="false" collective="false" import="true">
      <selectionEntries>
        <selectionEntry id="7223-41ce-b109-405f" name="Ejector Seats" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="f3e3-1fe6-7286-c676" type="max"/>
          </constraints>
          <rules>
            <rule id="b51f-fae3-28da-b335" name="Ejector Seats" hidden="false">
              <description>If the aircraft is destroyed roll a D6. On a 1-3 nothing happens. On a 4+ the crewman successfully ejects. Roll a Scatter Dice and 4D6&quot; for the direction and distance from the aircraft the crewman lands. Each crewman counts a single Guardsman with a laspistol. They are considered to be below half strength for the purposes of moral checks, claiming table quarters, etc. If any crew survice the aircraft will only count as damaged for the purposes of Victory Points at the end of the game.</description>
            </rule>
          </rules>
          <costs>
            <cost name="pts" typeId="4ed5-2f92-9abc-2870" value="10"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="b102-8704-62ee-0590" name="Flare/Chaff Launcher" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="0e3f-85e8-bef4-405c" type="max"/>
          </constraints>
          <rules>
            <rule id="3491-e046-3b5b-f2a4" name="Flare/Chaff Launcher" hidden="false">
              <description>One use only. If the vehicle takes the Immobilised damage result then re-roll the result.</description>
            </rule>
          </rules>
          <costs>
            <cost name="pts" typeId="4ed5-2f92-9abc-2870" value="5"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="3ccf-57f1-8189-4e99" name="Armoured Cockpit" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="1b8e-94d2-d6d3-6e0e" type="max"/>
          </constraints>
          <rules>
            <rule id="4850-ef62-40b7-3fa5" name="Armoured Cockpit" hidden="false">
              <description>If the aircraft takes the Crew Shaken, Crew Stunned, or Pilot Shaken result, then roll a D6. On a 4+ the result is ignored.</description>
            </rule>
          </rules>
          <costs>
            <cost name="pts" typeId="4ed5-2f92-9abc-2870" value="20"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="069b-ded7-760e-9b43" name="Infrared Targeting" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="0502-b3f8-c05f-9021" type="max"/>
          </constraints>
          <rules>
            <rule id="68dc-1a46-82b9-aa89" name="Infrared Targeting" hidden="false">
              <description>The aircraft can re-roll the dice for the distance it can engage enemiers during a Night Fighting mission.</description>
            </rule>
          </rules>
          <costs>
            <cost name="pts" typeId="4ed5-2f92-9abc-2870" value="10"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="4324-8c35-91c2-d609" name="Illum Flare" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="305d-01f1-b5fa-7528" type="max"/>
          </constraints>
          <rules>
            <rule id="96b6-2f12-2db8-4271" name="Illum Flare" hidden="false">
              <description>This flare is used in missions where the Night Fighting rules are in effect. They allow one enemy unit spotted by the aircraft to be fired at in the next turn by any other ground forces in range and that have line of sight.</description>
            </rule>
          </rules>
          <costs>
            <cost name="pts" typeId="4ed5-2f92-9abc-2870" value="3"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="768a-3083-ab69-57d4" name="Nose Art" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="7153-37ca-c54f-5f51" type="max"/>
          </constraints>
          <rules>
            <rule id="33d4-604c-8bd1-3831" name="Nose Art" hidden="false">
              <description>In the player&apos;s own turn, after the aircraft has attacked in the opponent&apos;s turn, the first unit to fail a Moral test may re-roll the test.</description>
            </rule>
          </rules>
          <costs>
            <cost name="pts" typeId="4ed5-2f92-9abc-2870" value="10"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
  </sharedSelectionEntryGroups>
  <sharedRules>
    <rule id="af4c-0503-c81d-6237" name="Hammerhand" hidden="false">
      <description>This psykic power may be used at the beginning of any Assault phase. On a successful psychic test the psyker doubles their Strength until their next turn. The psyker also counts as having an additional close combat weapon. They may not benefit from any power weapons or other special close combat attacks while this power is active.</description>
    </rule>
    <rule id="5eef-907a-7737-8778" name="Scourging" hidden="false">
      <description>Scourging is a psychic power that may be used in the shooting phase instead of firing a weapon. Roll to hit, wound and save as normal, but invulnerable saves may not be taken against wounds caused by Scourging.</description>
    </rule>
    <rule id="4420-1044-af7b-ef63" name="Word of the Emperor" hidden="false">
      <description>This power can be used at the beginning of the enemy Assault phase, even if the psyker is engaged in close combat. All enemy units attempting to charge the psyker or his unit must pass a Leadership test. On a failure they may not assault that turn.</description>
    </rule>
    <rule id="d4ae-9c63-c202-23b0" name="The Acolyte" hidden="false">
      <description>An Inquisitor with an Acolyte Henchman may allocate wounds that he suffers to the Acolyte, but may only allocate one wound per phase. This must be done before any saving throws are attempted.</description>
    </rule>
    <rule id="a167-544a-1db8-c20a" name="The Sage" hidden="false">
      <description>An Inquisitor accompanied by a Sage benefits from +1 BS. If more than one Sage is in his retinue, the Inquisitor or a member of his retinue may re-roll a failed roll to hit during the Shooting Phase.</description>
    </rule>
    <rule id="d536-da50-2f8e-b9cf" name="The Warrior" hidden="false">
      <description>The Inquisitor gainst +1 WS if he has any warriors in his retinue.</description>
    </rule>
    <rule id="3daa-76d9-c1c5-1e5b" name="The Familiar" hidden="false">
      <description>An Inquisitor with a Familiar in his retinue benefits from +1 Initiative. For each Familiar in his retinue he may purchase one more psychic power than normally allowed.</description>
    </rule>
    <rule id="95a2-dff1-c457-8f3d" name="The Hierophant" hidden="false">
      <description>If an Inquisitor with a Hierophant in his retinue gain +1 Leadership. Daemons wishing to assault a unit including a Hierophant must roll dice for their Assault range as if moving in difficult ground. If the Inquisitor has two or more Hierophants in his retinue, Daemons within 6&quot; of the unit are at -1 Leadership.</description>
    </rule>
    <rule id="5597-f5b5-ee42-eb49" name="The Mystic" hidden="false">
      <description>If a unit of Daemons, a Greater Daemon, or a Deep Striking unit enters play with 4D6&quot; of an Inquisitor with a Mystic Henchment (roll when each unit enters play), both he and the rest of the retinue may immediately take a &apos;free&apos; shot at them. These shots are taken before the enemy unit moves and the unit counts as stationary. If the Inquisitor has two or more Mystics in his retinue he may instead nominate one unit with a model within 12&quot; of him to immediately take these free shots at the enemy unit.</description>
    </rule>
    <rule id="e9b2-e53b-2414-1a22" name="Targeter" hidden="false">
      <description>Models equipped with a targeter are allowed to pre-measure the range to a target before they decide who to shoot at in the Shooting phase. This ability must be used after all Guess ranged weapons have been used this turn, otherwise those weapons cannot fire this turn.</description>
    </rule>
    <rule id="65fb-6995-c919-09dd" name="Amphibious" hidden="false">
      <description>Treat all water features as clear terrain when moving</description>
    </rule>
    <rule id="c854-97b0-3b8d-c5d4" name="Vox-Caster" hidden="false">
      <description>If a unit containing an Officer has a vo-xcaster, then one squad per turn that also has a vox-caster may use the Leadership ability of the officer regardless of distance. The benefits of standards and trademark items are not conveyed through the vox-caster</description>
    </rule>
    <rule id="4053-eb3d-7c9c-241d" name="Bionics" hidden="false">
      <description>When a model with bionics is killed, instead place it on its side. Roll a D6 at the start of the next turn: on a roll of 6 the model stands back up with 1 wound, but on any other roll it is removed as a casualty.</description>
    </rule>
    <rule id="f219-56c3-ab1b-6ccd" name="And They Shall Know No Fear" hidden="false">
      <description>Space Marines automatically regroup as they fall back, even if the squad is reduced to less than 50% by casualties, but not if the squad is out of coherency or there are enemy models within 6&quot;. If the enemy advance into them the Space Marines are not destroyed and the new assault is treated in the same way as a sweeping advance (enemy gaining +1 A next turn).</description>
    </rule>
    <rule id="424f-c543-4ada-a802" name="Simulacrum Imperialis" hidden="false">
      <description>The presence of the Simulacrum Imperialis allows a Faithful unit to roll one extra dice when making a Test of Faith and choose which two dice to use. This may be used once per player turn.</description>
    </rule>
    <rule id="e0c1-d20d-07d0-d891" name="Servo-skill" hidden="false">
      <description>An Inquisitor with a Familiar in his retinue benefits from +1 Initiative. For each Familiar in his retinue he may purchase one more psychic power than normally allowed.</description>
    </rule>
    <rule id="a2e6-23ed-cf18-a4c0" name="Rosarius" hidden="false">
      <description>4+ Invulnerable save</description>
    </rule>
    <rule id="0f6e-e675-24a7-6676" name="Master-crafted" hidden="false">
      <description>The bearer may re-roll one failed to hit roll per turn.</description>
    </rule>
    <rule id="3823-309e-5e93-c233" name="Inquisitorial Mandate" hidden="false">
      <description>A model bearing an Inquisitorial Mandate may reveal it once per battle. This may be done at any time, as long as the model with the Mandate does not move in the turn it is revealed. On the turn the Mandate is revealed, all friendly models with 2D6&quot; recieve a +1 Attack bonus for the rest of that turn.</description>
    </rule>
    <rule id="6272-21de-c79d-2f70" name="VTOL Hover Mode" hidden="false">
      <description>Rather than leave the table as per normal, the flyer may choose to engage is VTOL Hover mode to remain on the table. It remains stationary, but can turn in any direction to bring its weapons to bear. It may fire all of its weapons.
For the purposes of being fired at, the vehicle counts as a moving Skimmer. It can therefore be fired at using the firer&apos;s normal BS. All hits are treated as glancing hits. It can only be attack in close combat by attackers that can fly or have jump packs, in which case it is treated as a moving vehicle.
If the vehicle is immobilised the model is destroyed.
At the end of its own turn, the vehicle may disengage VTOL. It not reverts to being a flyer. It cannot return in the enemy turn immediately afer it leaves the table.</description>
    </rule>
    <rule id="6276-9058-bcbf-699e" name="Banishment" hidden="false">
      <description>Use this psychic power at the beginning of any Assault phase. Daemons in base contact with the psyker or the squad he is in with roll 3D6 when testing for instability, and use the two highest dice rolls.</description>
    </rule>
    <rule id="a048-6fe2-6f7e-0698" name="Destroy Daemon" hidden="false">
      <description>Use this psychic power at the beginning of any Assault phase. If the test if passes, any to hit or to wound rolls made by the character against Daemons may be re-rolled for the rest of the turn.</description>
    </rule>
    <rule id="00ba-4bbe-4cbf-6039" name="Holocaust" hidden="false">
      <description>Use this power in the Daemonhunter&apos;s Assault phase at Inititive 1. If the test is passed, place the Ordnance template anywhere in contact with the psyker. All models, friend or foe, under the template suffer a Strength 5 hit with normal armour saves. Those particually under the template are hit on a dice roll of 4+.</description>
    </rule>
    <rule id="eddc-2385-12c4-16aa" name="Sanctuary" hidden="false">
      <description>Use at the beginning of the psyker&apos;s turn. Daemons may not move with 3&quot; of the psyker for any reason. Daemons already within this radius are pushed directly away from him until they are 3&quot; distance. Any Daemon that enters play within 3&quot; of the psyker will be automatically destroyed. The effects of thsi power last until the psyker moves, shoots or uses another psychic power, although he may fight as normal in close combat.</description>
    </rule>
    <rule id="ae7b-f94d-367d-8d8f" name="Grimoire of True Names" hidden="false">
      <description>Daemons in base contact with the character equipped with this item halve their WS.</description>
    </rule>
    <rule id="46a5-f138-0fa9-e2bd" name="True Grit" hidden="false">
      <description>Grey Knights treat Storm Bolters as pistols when determining if they get a bonus dice for being armored with an additional close combat weapon. 


This bonus cannot be claimed in the turn the Grey Knights charged in Assault, and only applies to Grey Knights in power armour.</description>
    </rule>
    <rule id="edf8-3ae4-5bc1-bc2e" name="Grey Knight Deep Strike" hidden="false">
      <description>May Deep Strike even in missions which do not normally allow Deep Strike or Reserves.</description>
    </rule>
    <rule id="8241-bc63-2e4e-5077" name="The Aegis" hidden="false">
      <description>Grey Knights can resist enemy psychic powers by rolling D6 + highest Ld in the unit.


The enemy psyker must roll equal to or higher on a D6 + their own Ld to penetrate the Grey Knights&apos; defenses.


Grey Knights are also immune to all Minor Psychic Powers</description>
    </rule>
    <rule id="a3cc-ffbe-366d-1b07" name="The Shrouding" hidden="false">
      <description>Enemies must check if they can see Grey Knights when shooting at them


Roll 3D6 and multiply the result by 3. This is the nu,ber of inches the Grey Knights can be seen from.


Guess and Ordnance weapons double their scatter distance if the Grey Knights are out of spotting range.


Psykers may re-roll and accept the second result.</description>
    </rule>
    <rule id="6c89-0a33-95db-0039" name="Rites of Exorcism" hidden="false">
      <description>Daemons which take Instability tests suffer -1 to Leadership tests when in the presence of Grey Knights


Daemons must also take a Difficult Terrain test when charging Grey Knights</description>
    </rule>
    <rule id="9a2b-b350-8d62-39f6" name="Daemonic Infestation" hidden="false">
      <description>Daemon Packs, Nurglings, and Daemonic Beast Packs gain Sustained Attacks in any mission with Grey Knights present. 


Daemons re-enter from the table edge and cannot claim mission objectives.</description>
    </rule>
    <rule id="2fdd-cd0c-679e-fa46" name="Storm Shield" hidden="false">
      <description>Gain a 4+ invulnerable save in close combat against any one opponent per turn.</description>
    </rule>
  </sharedRules>
  <sharedProfiles>
    <profile id="be2f-7463-84ea-6b38" name="Scourging" hidden="false" typeId="b399-8a1b-bf0b-c5b7" typeName="Weapon">
      <characteristics>
        <characteristic name="Range" typeId="deb8-131d-bdcf-1376">18&quot;</characteristic>
        <characteristic name="S" typeId="24d8-2110-08fa-d844">5</characteristic>
        <characteristic name="AP" typeId="25ce-028f-0aae-2855">5</characteristic>
        <characteristic name="Type" typeId="d3f6-19e8-ac9e-ae13">Assault D6</characteristic>
        <characteristic name="Abilities" typeId="492d-1f80-b777-26f2">Ignores invulnerable saves</characteristic>
      </characteristics>
    </profile>
    <profile id="cbad-0802-c033-0aec" name="Henchman" hidden="false" typeId="1e16-2bd8-7cad-379b" typeName="Unit">
      <characteristics>
        <characteristic name="WS" typeId="c704-6128-f143-935a">3</characteristic>
