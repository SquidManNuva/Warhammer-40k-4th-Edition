    <selectionEntry id="2eda-f8b1-d925-0a07" name="Daemonhosts" hidden="false" collective="false" import="true" type="unit">
      <categoryLinks>
        <categoryLink id="31dd-4cd3-44c5-bfd5" name="Elites" hidden="false" targetId="6d25-b346-c314-6911" primary="true"/>
      </categoryLinks>
      <selectionEntryGroups>
        <selectionEntryGroup id="ec54-9097-6d6f-3a9b" name="Daemonhosts" hidden="false" collective="false" import="true" defaultSelectionEntryId="2ee7-c068-48a0-127e">
          <constraints>
            <constraint field="selections" scope="parent" value="1" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="9c2f-6f10-cc27-6918" type="min"/>
            <constraint field="selections" scope="parent" value="3" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="e558-2ae0-62e5-9be9" type="max"/>
          </constraints>
          <selectionEntries>
            <selectionEntry id="2ee7-c068-48a0-127e" name="Daemonhost" hidden="false" collective="false" import="true" type="model">
              <rules>
                <rule id="501b-f781-5312-97e9" name="Summoned" hidden="false">
                  <description>Daemonhosts may be held in reserve and enter play by Deep Strike, even in missions which do not normally allow Deep Strike or Reserves.</description>
                </rule>
                <rule id="2b04-8d77-5b5b-ee51" name="Psyker" hidden="false">
                  <description>Roll a D6 for each Daemonhost at the beginning of each of the Daemonhunter player&apos;s turns to determine which psychic power it can manifest unti the beginning of the next turn, at which point a new power is rolled. Daemonhosts automatically pass all Psychic tests, but their psychic powers may be countered by Psychic Hoods and other such items.

1. Terrify: All units within 12&quot; and not within a vehicle must immediately take a Pinning test

2. Re-knit Host Form: Immediately recovers all wounds

3. Teleport: May immediately move anywhere on the table not within 1&quot; of an enemy model or within impassable terrain &amp; scatters as with Deep Strike. May assault after performing this ability

4. Bloodboil: In the Shooting phase. place the Ordnance template over the Daemonhost. All models underneath (except the Daemonhost) takes a S3 AP2 hit

5. Timeshift: Can move 12&quot; and Assault 12&quot;. Doubles the number of attacks the Daemonhost can make

6. Warp Strength: Add +D3 to both the Daemonhost&apos;s Strength &amp; Toughness until the end of the turn</description>
                </rule>
                <rule id="8a06-4b7a-d65c-49d5" name="Daemonhost" hidden="false">
                  <description>Daemonhosts operate independently during the game and may not join units or ride in vehicles. For the purposes of mission objectives, Daemonhosts cannot capture table quarters, hold objectives, or count as surviving troops in a Meat Grinder mission.</description>
                </rule>
              </rules>
              <infoLinks>
                <infoLink id="ff48-58ac-4a21-743f" name="Daemonhost" hidden="false" targetId="04cc-377e-9ff8-421b" type="profile"/>
                <infoLink id="2c74-d885-93ab-e202" name="Fearless" hidden="false" targetId="b137-13a1-eb97-c5e5" type="rule"/>
                <infoLink id="45bd-6513-76df-e05f" name="Invulnerable Saving Throw" hidden="false" targetId="97b3-810d-a09e-872b" type="rule"/>
                <infoLink id="34f6-5530-6de9-d121" name="Independent Character" hidden="false" targetId="4a60-7f7e-c37f-a4d6" type="rule"/>
              </infoLinks>
              <costs>
                <cost name="pts" typeId="4ed5-2f92-9abc-2870" value="85"/>
              </costs>
            </selectionEntry>
          </selectionEntries>
        </selectionEntryGroup>
      </selectionEntryGroups>
      <costs>
        <cost name="pts" typeId="4ed5-2f92-9abc-2870" value="0"/>
      </costs>
    </selectionEntry>
