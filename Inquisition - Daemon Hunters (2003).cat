            <cost name="pts" typeId="4ed5-2f92-9abc-2870" value="2"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="7a56-6180-54a7-f665" name="Master-Crafted Weapon" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="2" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="0882-2180-86d7-d009" type="max"/>
          </constraints>
          <rules>
            <rule id="10cf-fe7e-ab90-c56c" name="Master-crafted Weapons" hidden="false">
              <description>The bearer may re-roll one failed to hit roll per turn.</description>
            </rule>
          </rules>
          <costs>
            <cost name="pts" typeId="4ed5-2f92-9abc-2870" value="15"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="6c20-a06a-2afa-8690" name="Medallion Crimson" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="17fa-36fa-cade-0379" type="max"/>
          </constraints>
          <rules>
            <rule id="4630-0d2e-826e-9fd8" name="Medallion Crimson" hidden="false">
              <description>The first time the bearer is wounded by an attack that causes instant death he takes a single wound instead.</description>
            </rule>
          </rules>
          <costs>
            <cost name="pts" typeId="4ed5-2f92-9abc-2870" value="15"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="4197-9efb-e9ac-efbe" name="Melta Bombs" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="bf98-9639-bbe5-3d5b" type="max"/>
