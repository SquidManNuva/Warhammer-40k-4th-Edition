    <selectionEntry id="27ee-b0a2-0c2a-b518" name="Ordo Malleus Inquisitor Lord" hidden="false" collective="false" import="true" type="unit">
      <constraints>
        <constraint field="selections" scope="force" value="1" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="27f8-6738-af68-38b3" type="max"/>
      </constraints>
      <rules>
        <rule id="1665-94a2-d292-4e88" name="Iron Will" hidden="false">
          <description>An Inquisitor Lord can choose whether to pass or fail any Morale or Pinning test he is called upton to make. Even if failure is normally automatic, the Lord may still choose whether to pass or fail the test.</description>
        </rule>
      </rules>
      <infoLinks>
        <infoLink id="c736-dd55-9814-c072" name="Inquisitor Lord" hidden="false" targetId="24fa-c93e-4475-b3e6" type="profile"/>
      </infoLinks>
      <categoryLinks>
