                    <constraint type="max" value="1" field="selections" scope="force" shared="true" id="d391-54a6-9751-6344" includeChildSelections="true"/>
                  </constraints>
                </selectionEntry>
              </selectionEntries>
            </selectionEntryGroup>
          </selectionEntryGroups>
        </selectionEntryGroup>
      </selectionEntryGroups>
    </selectionEntryGroup>
    <selectionEntryGroup id="0563-f3dc-3db7-5c09" name="Daemon Hunters Vehicle Upgrades" hidden="false" collective="false" import="true">
      <selectionEntries>
        <selectionEntry id="3dd4-be65-9b0a-077e" name="Extra Armor" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="4e00-2072-b8af-3d5b" type="max"/>
          </constraints>
          <rules>
            <rule id="fd4d-889f-a6ce-5575" name="Extra Armour" hidden="false">
              <description>Treat &apos;Crew Stunned&apos; results as &apos;Crew Shaken&apos; instead.</description>
            </rule>
          </rules>
          <costs>
            <cost name="pts" typeId="4ed5-2f92-9abc-2870" value="5"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="8f0e-407f-514e-22c5" name="Hunter-killer Missile" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="afaa-b222-3a96-a8ae" type="max"/>
          </constraints>
          <infoLinks>
            <infoLink id="8a90-dd18-3ee2-2e96" name="Hunter-killer Missile" hidden="false" targetId="86d5-c5a0-fc04-7f5a" type="profile"/>
