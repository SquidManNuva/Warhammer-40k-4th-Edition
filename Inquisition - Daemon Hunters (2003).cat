          <selectionEntries>
            <selectionEntry type="upgrade" import="true" name="Grimoire Pandaemonica " hidden="false" id="d4ea-cc39-80ed-ccfa">
              <profiles>
                <profile name="Grimoire Pandaemonica " typeId="7279-038a-b87a-ed0c" typeName="Abilities" hidden="false" id="981f-59b9-dd48-c1c5">
                  <characteristics>
                    <characteristic name="Description" typeId="a08a-36f8-2fd3-b843">The bearer can force his opponent to re-roll Daemonic Possession or a single Summoning roll each game turn</characteristic>
                  </characteristics>
                </profile>
              </profiles>
              <costs>
                <cost name="pts" typeId="4ed5-2f92-9abc-2870" value="25"/>
              </costs>
              <constraints>
                <constraint type="max" value="1" field="selections" scope="force" shared="true" id="8134-71f7-8d08-ad97" includeChildSelections="true"/>
              </constraints>
            </selectionEntry>
            <selectionEntry type="upgrade" import="true" name="Books of Pain" hidden="false" id="9adc-799d-71bd-bcb0" collective="false">
              <modifiers>
                <modifier type="set" value="true" field="hidden">
                  <conditionGroups>
                    <conditionGroup type="and">
                      <conditions>
                        <condition type="notInstanceOf" value="0" field="selections" scope="ancestor" childId="341c-1d2c-25d8-af97" shared="true" percentValue="false" includeChildSelections="false" includeChildForces="false"/>
                        <condition type="notInstanceOf" value="0" field="selections" scope="ancestor" childId="27ee-b0a2-0c2a-b518" shared="true" percentValue="false" includeChildSelections="false" includeChildForces="false"/>
                      </conditions>
                    </conditionGroup>
                  </conditionGroups>
                </modifier>
                <modifier type="set" value="true" field="hidden">
                  <conditionGroups>
                    <conditionGroup type="and">
                      <conditions>
                        <condition type="instanceOf" value="0" field="selections" scope="ancestor" childId="0ab5-d725-1cf5-ba03" shared="true" percentValue="false" includeChildSelections="false" includeChildForces="false"/>
                      </conditions>
                    </conditionGroup>
                  </conditionGroups>
                </modifier>
              </modifiers>
              <constraints>
                <constraint type="max" value="1" field="selections" scope="force" shared="true" id="5b79-cc73-c95a-5a70" percentValue="false" includeChildSelections="false" includeChildForces="false"/>
                <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="0e47-c99b-d8e4-22bc" percentValue="false" includeChildSelections="false" includeChildForces="false"/>
              </constraints>
              <rules>
                <rule name="Emperor&apos;s Tarot" id="5d22-6808-88db-712b" hidden="false">
                  <description>Both players roll a dice before deployment. If the dice rolls are different, the Daemonhunters player gets a +1 on the dice roll to ascertain who goes first. If the dice rolls are the same, he suffers -1 to the roll.</description>
                </rule>
              </rules>
              <costs>
                <cost name="pts" typeId="4ed5-2f92-9abc-2870" value="25"/>
              </costs>
            </selectionEntry>
          </selectionEntries>
          <modifiers>
            <modifier type="set" value="true" field="hidden">
              <conditions>
                <condition type="equalTo" value="0" field="selections" scope="force" childId="e6d5-bc03-5827-d5da" shared="true" includeChildSelections="true"/>
              </conditions>
            </modifier>
          </modifiers>
          <selectionEntryGroups>
            <selectionEntryGroup name="Weapons" id="e9ab-8dea-3b23-b64b" hidden="false">
              <selectionEntries>
                <selectionEntry type="upgrade" import="true" name="Sword of St. Aquitane" hidden="false" id="4389-4073-7fb9-48d0">
                  <rules>
                    <rule name="Daemon Weapon" id="466a-9dac-65d7-1d23" hidden="false">
                      <description>In any turn the bearer inflicts at least one casualty with the Daemon weapon, the wielder must take a Leadership test at the end of the turn. 


If the test is failed the wielder suffers a Perils of the Warp attack.</description>
                    </rule>
                  </rules>
                  <infoLinks>
                    <infoLink name="Power Weapon" id="863a-2b46-d422-1b6e" hidden="false" type="profile" targetId="5774-7187-2616-dd8a">
                      <modifiers>
                        <modifier type="set" value="Sword of St. Aquitane" field="name"/>
                        <modifier type="set" value="Ignores the target Armor Save (Sv) (but not Invulnerable Save). 


When specified, grants a bonus to S or Wounds on a fixed value regardless of target Toughness (T).


If this weapon causes a wound &amp; the bearer passes his Mastery test, he may force the entirety of the next game turn to be fought using Night Fight rules" field="492d-1f80-b777-26f2"/>
                      </modifiers>
                    </infoLink>
                  </infoLinks>
                  <costs>
                    <cost name="pts" typeId="4ed5-2f92-9abc-2870" value="25"/>
                  </costs>
                  <constraints>
                    <constraint type="max" value="1" field="selections" scope="force" shared="true" id="e234-2dec-79cf-4587" includeChildSelections="true"/>
                  </constraints>
                </selectionEntry>
                <selectionEntry type="upgrade" import="true" name="Blade of Phaedron" hidden="false" id="002c-d517-fd83-87b8">
                  <rules>
                    <rule name="Daemon Weapon" id="f580-3618-3d60-f635" hidden="false">
                      <description>In any turn the bearer inflicts at least one casualty with the Daemon weapon, the wielder must take a Leadership test at the end of the turn. 


If the test is failed the wielder suffers a Perils of the Warp attack.</description>
                    </rule>
                  </rules>
                  <profiles>
                    <profile name="Blade of Phaedron" typeId="7279-038a-b87a-ed0c" typeName="Abilities" hidden="false" id="21c2-5605-5cb9-172f">
                      <characteristics>
                        <characteristic name="Description" typeId="a08a-36f8-2fd3-b843">Wounds all Daemons on 2+ and adds +D3 to the bearer&apos;s Attacks characteristic when charging Daemons.</characteristic>
                      </characteristics>
                    </profile>
                  </profiles>
                  <costs>
                    <cost name="pts" typeId="4ed5-2f92-9abc-2870" value="15"/>
                  </costs>
