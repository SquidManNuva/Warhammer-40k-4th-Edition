    <selectionEntry id="2345-227b-eb20-31cf" name="Inquisitor Lord Torquemada Coteaz" hidden="false" collective="false" import="true" type="unit">
      <modifiers>
        <modifier type="set" field="c6be-ba2f-c25a-dbac" value="0">
          <conditions>
            <condition field="limit::4ed5-2f92-9abc-2870" scope="roster" value="1500" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" childId="any" type="lessThan"/>
          </conditions>
        </modifier>
      </modifiers>
      <constraints>
        <constraint field="selections" scope="force" value="1" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="c6be-ba2f-c25a-dbac" type="max"/>
      </constraints>
      <rules>
        <rule id="dafb-0c74-ecbf-0233" name="Annointed Daemonhammer" hidden="false">
          <description>Cortez may re-roll any failed rolls to wound with his Daemonhammer.</description>
        </rule>
        <rule id="5310-fbf8-846a-1ee3" name="Glovodan Eagle" hidden="false">
          <description>The Eagle grants Coteaz +1 I and +1 A, and does not count towards the number of Henchmen nor does it take up any additional space in a Transport vehicle.</description>
        </rule>
        <rule id="af12-3aa0-6460-f71b" name="Destroyer to Daemons" hidden="false">
          <description>All Daemons within 6&quot; of Coteaz sufer -1 to their Leadership value.</description>
        </rule>
        <rule id="a5f9-106c-06ca-bab6" name="Daemonhammer" hidden="false">
          <description>Counts a Thunder Hammer, however if fighting a Daemon the bearer will strike in Initiative order.</description>
        </rule>
      </rules>
      <infoLinks>
        <infoLink id="97b5-9b84-a3d7-befb" name="Coteaz" hidden="false" targetId="d09f-62ad-076a-229f" type="profile"/>
        <infoLink id="bac4-b230-c5b9-aa02" name="Bolt Pistol" hidden="false" targetId="e9ac-c779-51bb-3c9a" type="profile"/>
