    <selectionEntry id="2e61-10ad-9bf7-bd39" name="Brother-Captain Stern" hidden="false" collective="false" import="true" type="unit">
      <modifiers>
        <modifier type="set" field="e38a-abb3-d8c2-9f48" value="0">
          <conditions>
            <condition field="limit::4ed5-2f92-9abc-2870" scope="roster" value="1500" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" childId="any" type="lessThan"/>
          </conditions>
